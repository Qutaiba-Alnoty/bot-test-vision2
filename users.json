const fs = require("fs");

const DATA_FILE = "./users.json";


function loadUsers(){

if(!fs.existsSync(DATA_FILE))
return new Set();


let data =
JSON.parse(
fs.readFileSync(DATA_FILE)
);


return new Set(data);

}


function saveUsers(users){

fs.writeFileSync(
DATA_FILE,
JSON.stringify([...users])
);

}


const completedUsers = loadUsers();
